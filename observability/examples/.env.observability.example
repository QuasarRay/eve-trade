# Local service correlation and Collector endpoint
OBSERVABILITY_ENV=local
OBSERVABILITY_RUN_ID=manual-local
OTEL_SDK_DISABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Honeycomb ingestion (never commit real values)
HONEYCOMB_API_KEY=replace-with-ingest-key
HONEYCOMB_DATASET=eve-trade
HONEYCOMB_API_ENDPOINT=https://api.honeycomb.io:443
# Optional configuration key (not the ingest key) for best-effort triage board creation.
# HONEYCOMB_CONFIGURATION_KEY=replace-with-configuration-key
# Optional UI deep links
HONEYCOMB_TEAM_SLUG=replace-with-team-slug
HONEYCOMB_ENVIRONMENT_SLUG=replace-with-environment-slug

# Sentry issue and release integration
SENTRY_DSN=replace-with-project-dsn
SENTRY_AUTH_TOKEN=replace-with-token
SENTRY_ORG=replace-with-org-slug
SENTRY_PROJECT=replace-with-project-slug
# Optional account-specific hook; the event ID is appended as the final argument.
# SENTRY_AUTOFIX_COMMAND=sentry-autofix

# Failure behavior and optional storage
OBSERVABILITY_STRICT=false
OBS_STORAGE_BACKEND=local
# OBS_STORAGE_BACKEND=s3
# OBS_S3_BUCKET=replace-with-bucket
# OBS_S3_PREFIX=eve-trade-observability
# AWS_REGION=ap-southeast-2
