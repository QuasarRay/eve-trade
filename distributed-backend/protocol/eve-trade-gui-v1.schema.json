{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eve-trade.example/protocol/eve-trade-gui-v1.schema.json",
  "title": "EVE Trade GUI packet v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "interaction_id", "ui", "input"],
  "properties": {
    "schema_version": {"const": "eve-trade-gui.v1"},
    "interaction_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "ui": {
      "type": "object",
      "additionalProperties": false,
      "required": ["window", "control_id", "action"],
      "properties": {
        "window": {"type": "string", "minLength": 1},
        "control_id": {"type": "string", "minLength": 1},
        "action": {
          "enum": [
            "market_place_sell_order",
            "market_buy_from_sell_order",
            "market_cancel_order",
            "contract_create_item_exchange",
            "contract_accept_item_exchange",
            "direct_trade_offer",
            "direct_trade_accept",
            "direct_trade_cancel"
          ]
        }
      }
    },
    "input": {"type": "object"}
  }
}
