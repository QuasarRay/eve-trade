{
  "pubsub": [
    {
      "type": "nsq",
      "hosts": "127.0.0.1:4150",
      "authentication": {
        "required": true,
        "type": "mutual_tls",
        "credential_secret": "NSQ_CLIENT_TLS_SECRET"
      },
      "tls": {
        "required": true,
        "server_name": "nsqd.eve-trade.svc.cluster.local",
        "ca_secret": "NSQ_CA_CERTIFICATE"
      },
      "topics": {
        "settlement-work": {
          "name": "settlement-work",
          "subscriptions": {
            "trade-settlement-executor": {
              "name": "trade-settlement-executor"
            }
          }
        },
        "settlement-results": {
          "name": "settlement-results",
          "subscriptions": {
            "market-settlement-result-projection": {
              "name": "market-settlement-result-projection"
            }
          }
        }
      }
    }
  ]
}
